{
  "productName": "ACOM Fault Decoder",
  "version": "1.0.0",
  "identifier": "com.thedxshop.acom-fault-decoder",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "ACOM Fault Decoder — GW4WND",
        "width": 1400,
        "height": 1000,
        "minWidth": 1200,
        "minHeight": 800,
        "resizable": true,
        "fullscreen": false
